# MFA Reset Portal - environment variables (use instead of config files)
# Copy to .env and set values. Do not commit .env.

# --- Applications MFA & Set OTP database (same DB) ---
MFA_APPS_DB_SERVER=your-sql-server.domain.com
MFA_APPS_DB_NAME=MFADatabase
MFA_APPS_DB_USER=your-db-user
MFA_APPS_DB_PASSWORD=your-db-password

# --- VPN MFA database ---
MFA_VPN_DB_SERVER=your-sql-server.domain.com
MFA_VPN_DB_NAME=MFADatabaseVPN
MFA_VPN_DB_USER=your-db-user
MFA_VPN_DB_PASSWORD=your-db-password

# --- Set OTP database (optional; if unset, uses Applications DB above) ---
# MFA_OTP_DB_SERVER=your-sql-server.domain.com
# MFA_OTP_DB_NAME=MFADatabase
# MFA_OTP_DB_USER=your-db-user
# MFA_OTP_DB_PASSWORD=your-db-password

# --- Database driver (optional) ---
MFA_DB_DRIVER=ODBC Driver 17 for SQL Server

# --- LDAP / AD ---
MFA_LDAP_SERVER=your-dc.jdg.co.za
MFA_LDAP_PORT=389
MFA_LDAP_USE_LDAPS=0
MFA_LDAP_BIND_USER=jdg\\service-account
MFA_LDAP_BIND_PASSWORD=bind-password
MFA_LDAP_SEARCH_BASE=DC=jdg,DC=co,DC=za

# --- AD groups for role mapping (optional; fallback to config ADGroups) ---
# MFA_AD_GROUP_APP_MFA_RESET=jdg-adfs-mfa-registration-reset
# MFA_AD_GROUP_VPN_MFA_RESET=jdg-adfs-vpn-mfa-registration-reset
# MFA_AD_GROUP_OTP_SET=jdg-adfs-mfa-user-otp-registration-add

# --- Optional ---
# MFA_UPN_SUFFIX=jdg.co.za
# MFA_CONFIG=config.json
# FLASK_SECRET_KEY=your-secret-key
# FLASK_DEBUG=0
